## ====================================================================
##  Physics National Certificate — public/.htaccess
##  Front-controller routing + security hardening
## ====================================================================

RewriteEngine On

# Redirect HTTP -> HTTPS (production)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Allow real files / directories to be served as-is (uploads, static, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, route everything through index.php
RewriteRule ^ index.php [QSA,L]

## --------------------------------------------------------------------
##  Security headers (mirrored in PHP, here as defense-in-depth)
## --------------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

## --------------------------------------------------------------------
##  Block direct access to sensitive files
## --------------------------------------------------------------------
<FilesMatch "^(\.env|\.git|composer\.(json|lock)|README\.md|.*\.sql)$">
    Require all denied
</FilesMatch>

## --------------------------------------------------------------------
##  Disable script execution inside uploads/
## --------------------------------------------------------------------
<Directory "uploads">
    php_flag engine off
    Options -ExecCGI -Indexes
    AddType text/plain .php .php3 .phtml .phar
</Directory>

## --------------------------------------------------------------------
##  Compression
## --------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

## --------------------------------------------------------------------
##  Cache control for static assets
## --------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png  "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType text/css   "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>

## --------------------------------------------------------------------
##  Disable directory listing
## --------------------------------------------------------------------
Options -Indexes
DirectoryIndex index.php
