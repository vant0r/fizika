## Block PHP execution and directory listing inside upload directories
## Compatible with Apache 2.2+ and PHP as module/CGI/FPM
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
Options -ExecCGI -Indexes
AddType text/plain .php .php3 .php4 .php5 .phtml .phar .pht .pl .py .jsp .asp .htm .shtml .sh .cgi
<FilesMatch "\.(php|php3|php4|php5|phtml|phar|pht)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
