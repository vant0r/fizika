<script>
'use strict';

/* ===================================================================
   GLOBAL STATE
   =================================================================== */
const EXAM_ID    = <?= (int) $exam['id'] ?>;
let   CSRF_TOKEN = <?= json_encode($csrfToken, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>;

let questions = [];
let answers   = {};   // { qid: { answer, flag, ts } }
let currentIdx = 0;
let remaining = 0;
let timerHandle = null;
let saveQueue = new Map();
let saving = false;
let submitted = false;

/* ===================================================================
   FETCH HELPERS
   =================================================================== */
async function api(path, opts = {}) {
    const headers = Object.assign({
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': CSRF_TOKEN,
    }, opts.headers || {});
    if (opts.body && typeof opts.body !== 'string') {
        headers['Content-Type'] = 'application/json';
        opts.body = JSON.stringify(opts.body);
    }
    const res = await fetch(path, Object.assign({}, opts, { headers }));

    // Rolling CSRF: server may issue a fresh token on every response.
    const fresh = res.headers.get('X-CSRF-Token');
    if (fresh) CSRF_TOKEN = fresh;

    let data;
    try { data = await res.json(); } catch { data = {}; }
    if (!res.ok) throw new Error(data.error || ('HTTP ' + res.status));
    return data;
}

/* ===================================================================
   FULLSCREEN ENFORCEMENT
   =================================================================== */
function goFullscreen() {
    const el = document.documentElement;
    const req = el.requestFullscreen || el.webkitRequestFullscreen || el.msRequestFullscreen;
    if (req) req.call(el).catch(() => {});
}

/* ===================================================================
   BOOT — start session, fetch state, render
   =================================================================== */
async function boot() {
    try {
        await api(`/api/exam/${EXAM_ID}/start`, { method:'POST', body: {} });
    } catch (err) {
        alert('Imtihonni boshlab bo\'lmadi: ' + err.message);
        window.location.href = '/profile';
        return;
    }
    try {
        const st = await api(`/api/exam/${EXAM_ID}/state`);
        if (st.expired) { showResult({ expired: true }); return; }
        questions = st.questions || [];
        answers   = st.answers   || {};
        remaining = parseInt(st.remaining_seconds || 0, 10);
        renderNav();
        renderQuestion(0);
        startTimer();
    } catch (err) {
        alert('Sessiya yuklanmadi: ' + err.message);
        window.location.href = '/profile';
    }
}

/* ===================================================================
   QUESTION NAVIGATION
   =================================================================== */
function renderNav() {
    const nav = document.getElementById('qnav');
    nav.innerHTML = '';
    questions.forEach((q, i) => {
        const cell = document.createElement('div');
        cell.className = 'qcell';
        cell.textContent = String(i + 1);
        cell.addEventListener('click', () => renderQuestion(i));
        nav.appendChild(cell);
    });
    refreshNav();
}

function refreshNav() {
    const cells = document.querySelectorAll('#qnav .qcell');
    let answered = 0;
    cells.forEach((cell, i) => {
        const q = questions[i];
        const a = answers[q.id];
        cell.classList.toggle('is-current', i === currentIdx);
        const hasAns = a && a.answer !== null && a.answer !== '' && !(Array.isArray(a.answer) && a.answer.length === 0);
        cell.classList.toggle('is-answered', !!hasAns);
        cell.classList.toggle('is-flag', !!(a && a.flag));
        if (hasAns) answered++;
    });
    document.getElementById('answeredCounter').textContent = `${answered} / ${questions.length}`;
}

function renderQuestion(idx) {
    if (idx < 0 || idx >= questions.length) return;
    currentIdx = idx;
    const q = questions[idx];
    const a = answers[q.id] || { answer: null, flag: false };

    document.getElementById('qSection').textContent = q.section || '—';
    document.getElementById('qTitle').textContent  = `[ Savol #${idx + 1} / ${questions.length} ]`;
    document.getElementById('qBody').innerHTML     = q.question_text || '';

    const optsBox  = document.getElementById('qOptions');
    const openBox  = document.getElementById('qOpenAnswer');
    const matchBox = document.getElementById('qMatching');
    optsBox.innerHTML = '';
    openBox.classList.add('hidden');
    matchBox.classList.add('hidden');
    matchBox.innerHTML = '';

    if (q.type === 'mcq') {
        const opts = q.options || [];
        opts.forEach((opt, k) => {
            const div = document.createElement('label');
            div.className = 'opt';
            const isSel = String(a.answer) === String(opt.key ?? k);
            if (isSel) div.classList.add('is-selected');
            const value = opt.key ?? k;
            div.innerHTML = `
                <input type="radio" name="opt-${q.id}" value="${escapeHtml(String(value))}" ${isSel ? 'checked' : ''}>
                <span class="mono text-sm font-bold mr-2">[${String.fromCharCode(65 + k)}]</span>
                <span>${opt.text || opt.label || opt}</span>
            `;
            div.addEventListener('change', () => {
                answers[q.id] = Object.assign({}, a, { answer: value });
                refreshNav();
                queueSave(q.id);
                rerenderSelected();
            });
            optsBox.appendChild(div);
        });
    } else if (q.type === 'open') {
        openBox.classList.remove('hidden');
        const inp = document.getElementById('openAnswer');
        inp.value = a.answer ?? '';
        inp.oninput = () => {
            answers[q.id] = Object.assign({}, a, { answer: inp.value });
            refreshNav();
            queueSave(q.id);
        };
    } else if (q.type === 'matching') {
        matchBox.classList.remove('hidden');
        const left  = q.options?.left  || [];
        const right = q.options?.right || [];
        const cur   = (typeof a.answer === 'object' && a.answer !== null) ? a.answer : {};
        left.forEach((L, i) => {
            const row = document.createElement('div');
            row.className = 'flex items-center gap-3 mb-2';
            row.innerHTML = `
                <span class="brutal px-3 py-2 flex-1">${escapeHtml(String(L))}</span>
                <span class="mono">→</span>
                <select class="brutal p-2 flex-1" data-left="${escapeHtml(String(L))}">
                    <option value="">—</option>
                    ${right.map(R => `<option value="${escapeHtml(String(R))}" ${cur[L] === R ? 'selected' : ''}>${escapeHtml(String(R))}</option>`).join('')}
                </select>
            `;
            const sel = row.querySelector('select');
            sel.addEventListener('change', () => {
                cur[L] = sel.value || null;
                answers[q.id] = Object.assign({}, a, { answer: { ...cur } });
                refreshNav();
                queueSave(q.id);
            });
            matchBox.appendChild(row);
        });
    }

    document.getElementById('flagBtn').classList.toggle('btn-brutal', !!a.flag);
    document.getElementById('flagBtn').classList.toggle('btn-ghost',  !a.flag);

    refreshNav();
    typesetMath();
}

function rerenderSelected() {
    document.querySelectorAll('#qOptions .opt').forEach(el => {
        const inp = el.querySelector('input');
        el.classList.toggle('is-selected', inp.checked);
    });
}

function typesetMath() {
    if (window.MathJax && window.MathJax.typesetPromise) {
        window.MathJax.typesetPromise([document.getElementById('qBody'), document.getElementById('qOptions')]).catch(() => {});
    }
}

/* ===================================================================
   AUTOSAVE (debounced, queued)
   =================================================================== */
function queueSave(qid) {
    saveQueue.set(qid, answers[qid]);
    document.getElementById('autosaveLabel').textContent = '— saqlanmoqda... —';
    if (!saving) drainSaveQueue();
}

async function drainSaveQueue() {
    if (saving) return;
    saving = true;
    while (saveQueue.size > 0) {
        const [qid, payload] = saveQueue.entries().next().value;
        saveQueue.delete(qid);
        try {
            await api(`/api/exam/${EXAM_ID}/save`, {
                method: 'POST',
                body: { question_id: qid, answer: payload.answer, flag: !!payload.flag },
            });
        } catch (err) {
            console.warn('Save failed for', qid, err.message);
            if (err.message && err.message.toLowerCase().includes('vaqt tugagan')) {
                doSubmit(true);
                break;
            }
        }
    }
    saving = false;
    document.getElementById('autosaveLabel').textContent = '— hammasi saqlandi —';
}

/* ===================================================================
   TIMER
   =================================================================== */
function startTimer() {
    updateTimer();
    timerHandle = setInterval(() => {
        remaining = Math.max(0, remaining - 1);
        updateTimer();
        if (remaining <= 0) {
            clearInterval(timerHandle);
            doSubmit(true);
        }
    }, 1000);
}

function updateTimer() {
    const m = Math.floor(remaining / 60).toString().padStart(2, '0');
    const s = (remaining % 60).toString().padStart(2, '0');
    const box = document.getElementById('timerBox');
    box.textContent = `${m}:${s}`;
    box.classList.toggle('timer-warn', remaining <= 60);
}

/* ===================================================================
   SUBMIT
   =================================================================== */
async function doSubmit(forced = false) {
    if (submitted) return;
    if (!forced && !confirm('Imtihonni yakunlamoqchimisiz?')) return;
    submitted = true;
    if (timerHandle) clearInterval(timerHandle);

    // flush remaining saves
    await drainSaveQueue();

    try {
        const res = await api(`/api/exam/${EXAM_ID}/submit`, { method: 'POST', body: {} });
        showResult(res);
    } catch (err) {
        alert('Yakunlashda xato: ' + err.message);
        submitted = false;
    }
}

function showResult(r) {
    document.getElementById('resScore').textContent   = (r.score ?? 0).toFixed(1);
    document.getElementById('resGrade').textContent   = r.grade ?? '—';
    document.getElementById('resCorrect').textContent = r.correct_count ?? 0;
    document.getElementById('resWrong').textContent   = r.wrong_count ?? 0;
    document.getElementById('resSkipped').textContent = r.skipped_count ?? 0;

    const box = document.getElementById('resSections');
    box.innerHTML = '';
    (r.section_analysis || []).forEach(s => {
        const row = document.createElement('div');
        row.className = 'brutal p-3 flex items-center gap-3';
        row.innerHTML = `
            <div class="mono uppercase tracking-widest text-xs flex-1">${escapeHtml(s.section)}</div>
            <div class="mono text-xs">${s.correct}/${s.total}</div>
            <div class="flex-1 brutal h-2"><div style="height:100%;background:#000;width:${s.percent}%;"></div></div>
            <div class="mono font-extrabold text-sm w-14 text-right">${s.percent}%</div>
            ${s.weakness ? '<span class="brutal px-2 py-0.5 mono text-[10px] uppercase">zaif</span>' : ''}
        `;
        box.appendChild(row);
    });

    const m = document.getElementById('resultModal');
    m.classList.remove('hidden');
    m.classList.add('flex');
    if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
}

/* ===================================================================
   BUTTONS
   =================================================================== */
document.getElementById('prevBtn').addEventListener('click', () => renderQuestion(currentIdx - 1));
document.getElementById('nextBtn').addEventListener('click', () => renderQuestion(currentIdx + 1));
document.getElementById('submitBtn').addEventListener('click', () => doSubmit(false));
document.getElementById('exitBtn').addEventListener('click', () => {
    if (confirm('Imtihondan chiqsangiz, vaqt to\'xtamaydi. Davom etamizmi?')) {
        if (document.fullscreenElement) document.exitFullscreen();
        window.location.href = '/profile';
    }
});
document.getElementById('flagBtn').addEventListener('click', () => {
    const q = questions[currentIdx]; if (!q) return;
    const a = answers[q.id] || { answer: null, flag: false };
    a.flag = !a.flag;
    answers[q.id] = a;
    queueSave(q.id);
    refreshNav();
    renderQuestion(currentIdx);
});

document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    if (e.key === 'ArrowRight') renderQuestion(currentIdx + 1);
    else if (e.key === 'ArrowLeft') renderQuestion(currentIdx - 1);
    else if (e.key === 'f' || e.key === 'F') document.getElementById('flagBtn').click();
});

/* ===================================================================
   VIRTUAL SCRATCHPAD (HTML5 Canvas)
   =================================================================== */
(function initCanvas() {
    const canvas = document.getElementById('scratchPad');
    const ctx = canvas.getContext('2d');
    let drawing = false;
    let mode = 'pen'; // 'pen' | 'erase'
    let last = null;

    function resize() {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const img = canvas.width ? ctx.getImageData(0, 0, canvas.width, canvas.height) : null;
        canvas.width  = rect.width  * dpr;
        canvas.height = rect.height * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        if (img) ctx.putImageData(img, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    function pos(e) {
        const r = canvas.getBoundingClientRect();
        const t = (e.touches && e.touches[0]) || e;
        return { x: t.clientX - r.left, y: t.clientY - r.top };
    }

    function start(e) {
        e.preventDefault();
        drawing = true;
        last = pos(e);
    }
    function move(e) {
        if (!drawing) return;
        e.preventDefault();
        const p = pos(e);
        ctx.globalCompositeOperation = mode === 'erase' ? 'destination-out' : 'source-over';
        ctx.strokeStyle = '#000';
        ctx.lineWidth = mode === 'erase' ? 18 : 2;
        ctx.beginPath();
        ctx.moveTo(last.x, last.y);
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
        last = p;
    }
    function end() { drawing = false; last = null; }

    canvas.addEventListener('mousedown', start);
    canvas.addEventListener('mousemove', move);
    window.addEventListener('mouseup', end);
    canvas.addEventListener('touchstart', start, { passive: false });
    canvas.addEventListener('touchmove',  move,  { passive: false });
    canvas.addEventListener('touchend',   end);
    canvas.addEventListener('pointerdown', start);
    canvas.addEventListener('pointermove', move);
    canvas.addEventListener('pointerup',   end);

    document.getElementById('penBtn').addEventListener('click', () => {
        mode = 'pen';
        canvas.classList.remove('is-erasing');
        document.getElementById('penInfo').textContent = 'Qalam · 2px';
    });
    document.getElementById('eraseBtn').addEventListener('click', () => {
        mode = 'erase';
        canvas.classList.add('is-erasing');
        document.getElementById('penInfo').textContent = 'O\'chirgich · 18px';
    });
    document.getElementById('clearBtn').addEventListener('click', () => {
        if (!confirm('Qoralamani tozalash?')) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    });
})();

/* ===================================================================
   UTILS
   =================================================================== */
function escapeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, c => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
}

window.addEventListener('beforeunload', (e) => {
    if (!submitted) {
        e.preventDefault();
        e.returnValue = '';
    }
});

/* ===================================================================
   START
   =================================================================== */
goFullscreen();
boot();
</script>
</body>
</html>
