<script>
// Slider
(function(){
    const track=document.getElementById('slider-track'); if(!track)return;
    const slides=track.querySelectorAll('.slide'); if(slides.length<=1)return;
    const dots=document.querySelectorAll('#sl-dots .slider-dot');
    let idx=0,timer;
    function go(i){idx=((i%slides.length)+slides.length)%slides.length;track.style.transform='translateX(-'+idx*100+'%)';dots.forEach((d,k)=>d.classList.toggle('active',k===idx));}
    function start(){stop();timer=setInterval(()=>go(idx+1),5000);}
    function stop(){if(timer){clearInterval(timer);timer=null;}}
    document.getElementById('sl-prev')?.addEventListener('click',()=>{go(idx-1);start();});
    document.getElementById('sl-next')?.addEventListener('click',()=>{go(idx+1);start();});
    dots.forEach(d=>d.addEventListener('click',()=>{go(+d.dataset.slide);start();}));
    const sl=document.getElementById('hero-slider');
    sl.addEventListener('mouseenter',stop); sl.addEventListener('mouseleave',start);
    let tx=null;
    sl.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;},{passive:true});
    sl.addEventListener('touchend',e=>{if(tx===null)return;const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>40)go(idx+(dx<0?1:-1));tx=null;start();});
    start();
})();
// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{const el=document.getElementById(a.getAttribute('href').slice(1));if(el){e.preventDefault();el.scrollIntoView({behavior:'smooth'});}});});
</script>
