<script>
const USER_ID = <?= (int) $user['id'] ?>;
const $modal = document.getElementById('buyModal');
document.getElementById('openBuyModal').addEventListener('click', openBuyModal);
document.getElementById('closeBuyModal').addEventListener('click', closeBuyModal);
$modal.addEventListener('click', (e) => { if (e.target === $modal) closeBuyModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !$modal.classList.contains('hidden')) closeBuyModal(); });

async function openBuyModal() {
    $modal.classList.remove('hidden'); $modal.classList.add('flex');
    try {
        const res = await fetch('/api/tariffs', {headers:{'X-Requested-With':'XMLHttpRequest'}});
        const json = await res.json(); if (!res.ok) throw new Error(json.error || 'Xato');
        const list = document.getElementById('tariffList'); list.innerHTML = '';
        json.items.forEach(t => {
            const el = document.createElement('div');
            el.className = 'flex items-center justify-between p-4 rounded-xl border border-sky-100 hover:border-sky-300 hover:bg-sky-50/50 transition';
            el.innerHTML = `<div><div class="font-bold text-gray-900">${esc(t.name)}</div><div class="text-xs text-gray-500 mt-0.5">${t.mock_count} ta mock &middot; ${esc(t.description||'')}</div></div><div class="text-right"><div class="text-lg font-black text-sky-700">${fmtNum(t.price)}</div><div class="text-[10px] text-gray-400 uppercase">so'm</div></div>`;
            list.appendChild(el);
        });
        document.getElementById('botLink').href = `https://t.me/${json.bot_username}?start=${USER_ID}`;
    } catch (err) { document.getElementById('tariffList').innerHTML = `<div class="text-center text-sm text-red-500 py-4">${esc(err.message)}</div>`; }
}
function closeBuyModal() { $modal.classList.add('hidden'); $modal.classList.remove('flex'); }
function esc(s) { return String(s??'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function fmtNum(n) { return new Intl.NumberFormat('fr-FR').format(Number(n)||0); }

document.getElementById('logoutBtn').addEventListener('click', async () => {
    await fetch('/api/auth/logout', {method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}});
    window.location.href = '/auth';
});
</script>
