<script>
const USER_ID = <?= (int) $user['id'] ?>;
const CSRF_BUY = <?= json_encode($csrfBuy, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>;

const $modal = document.getElementById('buyModal');
document.getElementById('openBuyModal').addEventListener('click', openBuyModal);
document.getElementById('closeBuyModal').addEventListener('click', closeBuyModal);
$modal.addEventListener('click', (e) => { if (e.target === $modal) closeBuyModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !$modal.classList.contains('hidden')) closeBuyModal(); });

async function openBuyModal() {
    $modal.classList.remove('hidden');
    $modal.classList.add('flex');
    try {
        const res = await fetch('/api/tariffs', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'Tariflarni olishda xato');

        const list = document.getElementById('tariffList');
        list.innerHTML = '';
        json.items.forEach(t => {
            const card = document.createElement('div');
            card.className = 'brutal p-4 hover-fill flex items-center justify-between';
            card.innerHTML = `
                <div>
                    <div class="mono text-lg font-extrabold">${escapeHtml(t.name)}</div>
                    <div class="text-xs mono opacity-60 mt-0.5">${escapeHtml(t.description || '')}</div>
                    <div class="text-xs mono mt-1">${t.mock_count} ta mock imtihon</div>
                </div>
                <div class="text-right">
                    <div class="mono text-2xl font-black">${formatNum(t.price)}</div>
                    <div class="text-[10px] uppercase tracking-widest mono">so'm</div>
                </div>
            `;
            list.appendChild(card);
        });

        const url = `https://t.me/${json.bot_username}?start=${USER_ID}`;
        document.getElementById('botLink').href = url;
    } catch (err) {
        document.getElementById('tariffList').innerHTML =
            `<div class="brutal p-4 mono text-sm">Xato: ${escapeHtml(err.message)}</div>`;
    }
}
function closeBuyModal() {
    $modal.classList.add('hidden');
    $modal.classList.remove('flex');
}

function escapeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, c => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
}
function formatNum(n) {
    return new Intl.NumberFormat('fr-FR').format(Number(n) || 0);
}

// Logout
document.getElementById('logoutBtn').addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method:'POST', headers: { 'X-Requested-With':'XMLHttpRequest' } });
    window.location.href = '/auth';
});
</script>
