    <script>
        // ===== Flip control =====
        const flipper = document.getElementById('flipper');
        document.getElementById('toRegister').addEventListener('click', () => {
            flipper.classList.add('is-register');
            setTimeout(() => document.getElementById('rg_name').focus(), 600);
        });
        document.getElementById('toLogin').addEventListener('click', () => {
            flipper.classList.remove('is-register');
            setTimeout(() => document.getElementById('li_phone').focus(), 600);
        });

        // ===== Password show/hide =====
        document.querySelectorAll('[data-toggle]').forEach(btn => {
            btn.addEventListener('click', () => {
                const id = btn.getAttribute('data-toggle');
                const inp = document.getElementById(id);
                inp.type = inp.type === 'password' ? 'text' : 'password';
                btn.textContent = inp.type === 'password' ? 'show' : 'hide';
            });
        });

        // ===== Helpers =====
        function showError(boxId, message) {
            const el = document.getElementById(boxId);
            el.textContent = message;
            el.classList.remove('hidden');
        }
        function hideError(boxId) {
            document.getElementById(boxId).classList.add('hidden');
        }
        function setBusy(form, busy) {
            const btn = form.querySelector('button[type=submit]');
            btn.disabled = busy;
            btn.style.opacity = busy ? .5 : 1;
            btn.style.cursor = busy ? 'wait' : 'pointer';
        }

        // ===== LOGIN =====
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError('li_err');
            const form = e.currentTarget;
            const data = Object.fromEntries(new FormData(form).entries());
            setBusy(form, true);
            try {
                const res = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': data._csrf,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify(data),
                });
                // Rolling CSRF: replace stale token regardless of outcome
                const fresh = res.headers.get('X-CSRF-Token');
                if (fresh) form.querySelector('input[name=_csrf]').value = fresh;

                const json = await res.json();
                if (!res.ok) throw new Error(json.error || 'Login failed');

                // 2FA gate: if response demands 2FA, reveal the prompt instead of redirecting.
                if (json?.data?.requires_2fa) {
                    show2faPrompt(json.data.partial_token, json.data.expires_in || 300);
                    return;
                }

                const role = json?.data?.role || 'student';
                window.location.href = role === 'admin' ? '/admin' : '/profile';
            } catch (err) {
                showError('li_err', err.message);
            } finally {
                setBusy(form, false);
            }
        });

        // ===== 2FA PROMPT (admins) =====
        let _2faPartial = null;
        let _2faTimer   = null;
        function show2faPrompt(partialToken, expiresIn) {
            _2faPartial = partialToken;
            // Hide the login form and show the 2FA prompt overlay
            const overlay = document.getElementById('tfaOverlay');
            overlay.classList.remove('hidden');
            overlay.classList.add('flex');
            document.querySelector('#tfaCode').focus();

            // Countdown
            let remaining = expiresIn;
            const tEl = document.getElementById('tfaTimer');
            const tick = () => {
                if (--remaining <= 0) {
                    clearInterval(_2faTimer);
                    showError('tfaErr', 'Sessiya muddati o\'tdi. Qaytadan kirishga urinib ko\'ring.');
                    return;
                }
                const m = Math.floor(remaining / 60).toString().padStart(2, '0');
                const s = (remaining % 60).toString().padStart(2, '0');
                tEl.textContent = `${m}:${s}`;
            };
            tick();
            if (_2faTimer) clearInterval(_2faTimer);
            _2faTimer = setInterval(tick, 1000);
        }

        document.getElementById('tfaForm')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError('tfaErr');
            const code = document.getElementById('tfaCode').value.trim();
            if (!code) return showError('tfaErr', 'Kod kiriting');
            try {
                const res = await fetch('/api/auth/login/verify-2fa', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify({ partial_token: _2faPartial, code }),
                });
                const json = await res.json();
                if (!res.ok) throw new Error(json.error || 'Verification failed');
                const role = json?.data?.role || 'student';
                window.location.href = role === 'admin' ? '/admin' : '/profile';
            } catch (err) {
                showError('tfaErr', err.message);
            }
        });

        document.getElementById('tfaCancel')?.addEventListener('click', () => {
            const overlay = document.getElementById('tfaOverlay');
            overlay.classList.add('hidden');
            overlay.classList.remove('flex');
            if (_2faTimer) clearInterval(_2faTimer);
            _2faPartial = null;
            document.getElementById('tfaCode').value = '';
        });

        // ===== REGISTER (Stage A: form → OTP) =====
        let registrationData = null;       // cached payload for resend
        let otpExpiresAt     = 0;
        let otpTimerHandle   = null;
        let resendInHandle   = null;

        function showOtpStage(meta, formData) {
            registrationData = formData;
            document.getElementById('registerForm').classList.add('hidden');
            const otpForm = document.getElementById('otpForm');
            otpForm.classList.remove('hidden');
            document.getElementById('rg_title').textContent = '[ TASDIQLASH ]';
            document.getElementById('rg_step').textContent  = 'KOD KIRITING';
            document.getElementById('otp_phone').textContent = meta.phone_masked || '';
            document.getElementById('otp_challenge_id').value = meta.challenge_id;

            // Start timers
            otpExpiresAt = Date.now() + ((meta.expires_in || 300) * 1000);
            startOtpTimer();
            startResendCooldown(60);

            const cells = document.querySelectorAll('.otp-cell');
            cells.forEach(c => (c.value = ''));
            cells[0]?.focus();
        }

        function showFormStage() {
            document.getElementById('otpForm').classList.add('hidden');
            document.getElementById('registerForm').classList.remove('hidden');
            document.getElementById('rg_title').textContent = "[ RO'YXAT ]";
            document.getElementById('rg_step').textContent  = '02 / 02';
            if (otpTimerHandle) clearInterval(otpTimerHandle);
            if (resendInHandle) clearInterval(resendInHandle);
        }

        function startOtpTimer() {
            if (otpTimerHandle) clearInterval(otpTimerHandle);
            const tick = () => {
                const remaining = Math.max(0, Math.floor((otpExpiresAt - Date.now()) / 1000));
                const m = Math.floor(remaining / 60).toString().padStart(2, '0');
                const s = (remaining % 60).toString().padStart(2, '0');
                document.getElementById('otp_timer').textContent = `${m}:${s}`;
                if (remaining <= 0) {
                    clearInterval(otpTimerHandle);
                    showError('otp_err', 'Kod muddati tugadi. Qayta yuboring.');
                }
            };
            tick();
            otpTimerHandle = setInterval(tick, 500);
        }

        function startResendCooldown(seconds) {
            const btn = document.getElementById('otp_resend');
            const span = document.getElementById('otp_resend_in');
            btn.disabled = true; btn.style.opacity = .5;
            let left = seconds;
            span.textContent = left;
            if (resendInHandle) clearInterval(resendInHandle);
            resendInHandle = setInterval(() => {
                left -= 1; span.textContent = left;
                if (left <= 0) {
                    clearInterval(resendInHandle);
                    btn.disabled = false; btn.style.opacity = 1;
                    btn.innerHTML = 'qayta yuborish';
                }
            }, 1000);
        }

        // OTP cell auto-advance + paste
        const otpCells = document.querySelectorAll('.otp-cell');
        otpCells.forEach((cell, i) => {
            cell.addEventListener('input', (e) => {
                cell.value = cell.value.replace(/\D/g, '').slice(0, 1);
                if (cell.value && i < otpCells.length - 1) otpCells[i + 1].focus();
            });
            cell.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !cell.value && i > 0) otpCells[i - 1].focus();
            });
            cell.addEventListener('paste', (e) => {
                e.preventDefault();
                const txt = (e.clipboardData?.getData('text') || '').replace(/\D/g, '').slice(0, 6);
                txt.split('').forEach((d, k) => { if (otpCells[k]) otpCells[k].value = d; });
                otpCells[Math.min(txt.length, otpCells.length - 1)].focus();
            });
        });

        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError('rg_err');
            const form = e.currentTarget;
            const data = Object.fromEntries(new FormData(form).entries());
            setBusy(form, true);
            try {
                const res = await fetch('/api/auth/register', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': data._csrf,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify(data),
                });
                const fresh = res.headers.get('X-CSRF-Token');
                if (fresh) {
                    form.querySelector('input[name=_csrf]').value = fresh;
                    document.getElementById('otpForm').querySelector('input[name=_csrf]').value = fresh;
                }
                const json = await res.json();
                if (!res.ok) throw new Error(json.error || 'Registration failed');
                showOtpStage(json.data, data);
            } catch (err) {
                showError('rg_err', err.message);
            } finally {
                setBusy(form, false);
            }
        });

        // ===== REGISTER (Stage B: OTP verify) =====
        document.getElementById('otpForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            hideError('otp_err');
            const form = e.currentTarget;
            const code = Array.from(otpCells).map(c => c.value || '').join('');
            if (code.length !== 6) {
                showError('otp_err', 'Iltimos 6 xonali kodni to\'liq kiriting');
                return;
            }
            setBusy(form, true);
            try {
                const csrf = form.querySelector('input[name=_csrf]').value;
                const res = await fetch('/api/auth/register/verify', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': csrf,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify({
                        _csrf: csrf,
                        challenge_id: parseInt(document.getElementById('otp_challenge_id').value, 10),
                        code,
                    }),
                });
                const fresh = res.headers.get('X-CSRF-Token');
                if (fresh) form.querySelector('input[name=_csrf]').value = fresh;
                const json = await res.json();
                if (!res.ok) throw new Error(json.error || 'Verification failed');
                window.location.href = '/profile';
            } catch (err) {
                showError('otp_err', err.message);
            } finally {
                setBusy(form, false);
            }
        });

        document.getElementById('otp_back').addEventListener('click', showFormStage);

        document.getElementById('otp_resend').addEventListener('click', async () => {
            if (!registrationData) return;
            hideError('otp_err');
            const otpForm = document.getElementById('otpForm');
            const csrf = otpForm.querySelector('input[name=_csrf]').value;
            try {
                const res = await fetch('/api/auth/register/resend', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': csrf,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify(Object.assign({}, registrationData, { _csrf: csrf })),
                });
                const fresh = res.headers.get('X-CSRF-Token');
                if (fresh) otpForm.querySelector('input[name=_csrf]').value = fresh;
                const json = await res.json();
                if (!res.ok) throw new Error(json.error || 'Qayta yuborib bo\'lmadi');
                document.getElementById('otp_phone').textContent = json.data.phone_masked || '';
                document.getElementById('otp_challenge_id').value = json.data.challenge_id;
                otpExpiresAt = Date.now() + ((json.data.expires_in || 300) * 1000);
                startOtpTimer();
                startResendCooldown(60);
                otpCells.forEach(c => (c.value = ''));
                otpCells[0]?.focus();
            } catch (err) {
                showError('otp_err', err.message);
            }
        });

        // Focus first field
        document.getElementById('li_phone').focus();
    </script>
</body>
</html>
