<script>
'use strict';
// ===== Flip control =====
const flipper = document.getElementById('flipper');
document.getElementById('toRegister').addEventListener('click', () => {
    flipper.classList.add('flipped');
    setTimeout(() => document.getElementById('rg_name').focus(), 500);
});
document.getElementById('toLogin').addEventListener('click', () => {
    flipper.classList.remove('flipped');
    setTimeout(() => document.getElementById('li_phone').focus(), 500);
});

// ===== Password toggle =====
document.querySelectorAll('[data-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
        const inp = document.getElementById(btn.dataset.toggle);
        inp.type = inp.type === 'password' ? 'text' : 'password';
        btn.textContent = inp.type === 'password' ? "Ko'rish" : 'Yashirish';
    });
});

// ===== Helpers =====
function showError(id, msg) { const el = document.getElementById(id); el.textContent = msg; el.classList.remove('hidden'); }
function hideError(id) { document.getElementById(id).classList.add('hidden'); }
function setBusy(form, busy) {
    const btn = form.querySelector('button[type=submit]');
    btn.disabled = busy; btn.style.opacity = busy ? .6 : 1;
}

// ===== LOGIN =====
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault(); hideError('li_err');
    const form = e.currentTarget;
    const data = Object.fromEntries(new FormData(form).entries());
    setBusy(form, true);
    try {
        const res = await fetch('/api/auth/login', {
            method:'POST',
            headers:{'Content-Type':'application/json','X-CSRF-Token':data._csrf,'X-Requested-With':'XMLHttpRequest'},
            body: JSON.stringify(data),
        });
        const fresh = res.headers.get('X-CSRF-Token');
        if (fresh) form.querySelector('input[name=_csrf]').value = fresh;
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'Login failed');
        if (json?.data?.requires_2fa) { show2faPrompt(json.data.partial_token, json.data.expires_in||300); return; }
        window.location.href = (json?.data?.role === 'admin') ? '/admin' : '/profile';
    } catch (err) { showError('li_err', err.message); }
    finally { setBusy(form, false); }
});

// ===== 2FA =====
let _2faPartial = null, _2faTimer = null;
function show2faPrompt(token, exp) {
    _2faPartial = token;
    document.getElementById('tfaOverlay').classList.remove('hidden');
    document.getElementById('tfaOverlay').classList.add('flex');
    document.getElementById('tfaCode').focus();
    let rem = exp;
    const tick = () => { rem--; const m=Math.floor(rem/60).toString().padStart(2,'0'); const s=(rem%60).toString().padStart(2,'0'); document.getElementById('tfaTimer').textContent=m+':'+s; if(rem<=0)clearInterval(_2faTimer); };
    tick(); _2faTimer = setInterval(tick, 1000);
}
document.getElementById('tfaForm')?.addEventListener('submit', async (e) => {
    e.preventDefault(); hideError('tfaErr');
    const code = document.getElementById('tfaCode').value.trim();
    if (!code) return showError('tfaErr','Kod kiriting');
    try {
        const res = await fetch('/api/auth/login/verify-2fa', { method:'POST', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'}, body:JSON.stringify({partial_token:_2faPartial,code}) });
        const json = await res.json(); if(!res.ok) throw new Error(json.error||'Failed');
        window.location.href = (json?.data?.role === 'admin') ? '/admin' : '/profile';
    } catch(err) { showError('tfaErr', err.message); }
});
document.getElementById('tfaCancel')?.addEventListener('click', () => {
    document.getElementById('tfaOverlay').classList.add('hidden');
    document.getElementById('tfaOverlay').classList.remove('flex');
    if(_2faTimer) clearInterval(_2faTimer);
});


// ===== REGISTER (OTP flow) =====
let registrationData = null, otpExpiresAt = 0, otpTimerH = null, resendH = null;

function showOtpStage(meta, formData) {
    registrationData = formData;
    document.getElementById('registerForm').classList.add('hidden');
    document.getElementById('otpForm').classList.remove('hidden');
    document.getElementById('rg_title').textContent = 'Tasdiqlash kodi';
    document.getElementById('rg_subtitle').textContent = 'SMS orqali yuborilgan kodni kiriting';
    document.getElementById('otp_phone').textContent = meta.phone_masked || '';
    document.getElementById('otp_challenge_id').value = meta.challenge_id;
    otpExpiresAt = Date.now() + ((meta.expires_in||300)*1000);
    startOtpTimer(); startResendCooldown(60);
    document.querySelectorAll('.otp-cell').forEach(c=>(c.value='')); document.querySelector('.otp-cell')?.focus();
}
function showFormStage() {
    document.getElementById('otpForm').classList.add('hidden');
    document.getElementById('registerForm').classList.remove('hidden');
    document.getElementById('rg_title').textContent = "Ro'yxatdan o'tish";
    document.getElementById('rg_subtitle').textContent = 'Yangi hisob yaratish';
    if(otpTimerH) clearInterval(otpTimerH); if(resendH) clearInterval(resendH);
}
function startOtpTimer() {
    if(otpTimerH) clearInterval(otpTimerH);
    const tick = () => { const r=Math.max(0,Math.floor((otpExpiresAt-Date.now())/1000)); document.getElementById('otp_timer').textContent=Math.floor(r/60).toString().padStart(2,'0')+':'+(r%60).toString().padStart(2,'0'); if(r<=0){clearInterval(otpTimerH);showError('otp_err','Kod muddati tugadi');} };
    tick(); otpTimerH = setInterval(tick, 500);
}
function startResendCooldown(s) {
    const btn=document.getElementById('otp_resend'), sp=document.getElementById('otp_resend_in');
    btn.disabled=true; let left=s; sp.textContent=left;
    if(resendH) clearInterval(resendH);
    resendH = setInterval(()=>{ left--; sp.textContent=left; if(left<=0){clearInterval(resendH); btn.disabled=false; btn.innerHTML='Qayta yuborish';} }, 1000);
}

// OTP cells auto-advance
const otpCells = document.querySelectorAll('.otp-cell');
otpCells.forEach((c,i) => {
    c.addEventListener('input', () => { c.value=c.value.replace(/\D/g,'').slice(0,1); if(c.value&&i<otpCells.length-1) otpCells[i+1].focus(); });
    c.addEventListener('keydown', (e) => { if(e.key==='Backspace'&&!c.value&&i>0) otpCells[i-1].focus(); });
    c.addEventListener('paste', (e) => { e.preventDefault(); const t=(e.clipboardData?.getData('text')||'').replace(/\D/g,'').slice(0,6); t.split('').forEach((d,k)=>{if(otpCells[k])otpCells[k].value=d;}); otpCells[Math.min(t.length,otpCells.length-1)].focus(); });
});

document.getElementById('registerForm').addEventListener('submit', async (e) => {
    e.preventDefault(); hideError('rg_err');
    const form = e.currentTarget; const data = Object.fromEntries(new FormData(form).entries());
    setBusy(form, true);
    try {
        const res = await fetch('/api/auth/register', { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':data._csrf,'X-Requested-With':'XMLHttpRequest'}, body:JSON.stringify(data) });
        const fresh = res.headers.get('X-CSRF-Token');
        if(fresh) form.querySelector('input[name=_csrf]').value=fresh;
        const json = await res.json(); if(!res.ok) throw new Error(json.error||'Failed');
        // Direct redirect — no OTP step
        window.location.href = (json?.data?.role === 'admin') ? '/admin' : '/profile';
    } catch(err) { showError('rg_err', err.message); }
    finally { setBusy(form, false); }
});

document.getElementById('otpForm').addEventListener('submit', async (e) => {
    e.preventDefault(); hideError('otp_err');
    const form = e.currentTarget;
    const code = Array.from(otpCells).map(c=>c.value||'').join('');
    if(code.length!==6) return showError('otp_err',"6 xonali kodni to'liq kiriting");
    setBusy(form, true);
    try {
        const csrf = form.querySelector('input[name=_csrf]').value;
        const res = await fetch('/api/auth/register/verify', { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':csrf,'X-Requested-With':'XMLHttpRequest'}, body:JSON.stringify({_csrf:csrf, challenge_id:parseInt(document.getElementById('otp_challenge_id').value,10), code}) });
        const fresh=res.headers.get('X-CSRF-Token'); if(fresh) form.querySelector('input[name=_csrf]').value=fresh;
        const json=await res.json(); if(!res.ok) throw new Error(json.error||'Failed');
        window.location.href='/profile';
    } catch(err) { showError('otp_err', err.message); }
    finally { setBusy(form, false); }
});

document.getElementById('otp_back').addEventListener('click', showFormStage);
document.getElementById('otp_resend').addEventListener('click', async () => {
    if(!registrationData) return; hideError('otp_err');
    const csrf = document.getElementById('otpForm').querySelector('input[name=_csrf]').value;
    try {
        const res = await fetch('/api/auth/register/resend', { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':csrf,'X-Requested-With':'XMLHttpRequest'}, body:JSON.stringify(Object.assign({},registrationData,{_csrf:csrf})) });
        const fresh=res.headers.get('X-CSRF-Token'); if(fresh) document.getElementById('otpForm').querySelector('input[name=_csrf]').value=fresh;
        const json=await res.json(); if(!res.ok) throw new Error(json.error||'Failed');
        document.getElementById('otp_challenge_id').value=json.data.challenge_id;
        otpExpiresAt=Date.now()+((json.data.expires_in||300)*1000); startOtpTimer(); startResendCooldown(60);
        otpCells.forEach(c=>(c.value='')); otpCells[0]?.focus();
    } catch(err) { showError('otp_err', err.message); }
});

document.getElementById('li_phone').focus();
</script>
</body>
</html>
