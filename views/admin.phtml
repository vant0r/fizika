async function loadPayments(status) {
    const body = document.getElementById('paymentsBody');
    body.innerHTML = '<div class="row p-6 text-center mono text-sm opacity-60">Yuklanmoqda...</div>';
    try {
        const d = await api('/api/admin/payments?status=' + encodeURIComponent(status));
        renderPayments(d.items, status);
    } catch (e) {
        body.innerHTML = `<div class="row p-6 text-center mono text-sm">Xato: ${escapeHtml(e.message)}</div>`;
    }
}

function renderPayments(items, status) {
    const body = document.getElementById('paymentsBody');
    if (!items || items.length === 0) {
        body.innerHTML = '<div class="row p-6 text-center mono text-sm opacity-60">— bo\'sh —</div>';
        return;
    }
    body.innerHTML = '';
    for (const p of items) {
        const row = document.createElement('div');
        row.className = 'grid grid-cols-12 row hover-fill text-sm';
        const actions = status === 'pending'
            ? `<button class="btn-brutal" data-act="approve" data-id="${p.id}">✓ Tasdiqlash</button>
               <button class="btn-danger" data-act="reject"  data-id="${p.id}">✗ Rad etish</button>`
            : `<span class="mono text-[10px] uppercase tracking-widest opacity-60">${escapeHtml(p.note || '—')}</span>`;
        row.innerHTML = `
            <div class="cell p-3 col-span-1 mono">#${p.id}</div>
            <div class="cell p-3 col-span-3">
                <div class="font-bold">${escapeHtml(p.fullname || '—')}</div>
                <div class="mono text-xs opacity-60">${escapeHtml(p.phone || '')}${p.tg_user_id ? ' &middot; tg:' + p.tg_user_id : ''}</div>
            </div>
            <div class="cell p-3 col-span-2 mono text-xs">
                ${escapeHtml(p.tariff_name || '—')}
                <div class="opacity-60">${p.mock_count} mock</div>
            </div>
            <div class="cell p-3 col-span-1 mono text-right font-bold">${formatNum(p.amount)}</div>
            <div class="cell p-3 col-span-1 text-center">
                <button class="btn-ghost" data-act="view" data-shot="${escapeAttr(p.screenshot_path)}">Ko'rish</button>
            </div>
            <div class="cell p-3 col-span-2 text-center mono text-xs">${escapeHtml((p.created_at || '').replace('T', ' '))}</div>
            <div class="p-3 col-span-2 flex items-center justify-center gap-2">${actions}</div>
        `;
        body.appendChild(row);
    }
}

document.getElementById('paymentsBody').addEventListener('click', async (e) => {
    const btn = e.target.closest('button[data-act]');
    if (!btn) return;
    const act = btn.dataset.act;
    if (act === 'view') {
        document.getElementById('shotImg').src = btn.dataset.shot;
        document.getElementById('shotModal').classList.add('show');
        return;
    }
    if (act === 'approve') {
        if (!confirm(`To'lov #${btn.dataset.id} tasdiqlansinmi? Foydalanuvchining mock kvota va balansi yangilanadi va botga xabar ketadi.`)) return;
        btn.disabled = true; btn.textContent = '...';
        try {
            await api(`/api/admin/payments/${btn.dataset.id}/approve`, { method: 'POST', body: {} });
            toast('Tasdiqlandi · TG xabar yuborildi');
            loadPayments(currentPaymentStatus);
            loadDashboard();
        } catch (err) { toast(err.message, 'error'); btn.disabled = false; btn.textContent = '✓ Tasdiqlash'; }
        return;
    }
    if (act === 'reject') {
        document.getElementById('rejectId').textContent = btn.dataset.id;
        document.getElementById('rejectModal').dataset.id = btn.dataset.id;
        document.getElementById('rejectNote').value = '';
        document.getElementById('rejectModal').classList.add('show');
    }
});

document.getElementById('confirmRejectBtn').addEventListener('click', async () => {
    const id = document.getElementById('rejectModal').dataset.id;
    const note = document.getElementById('rejectNote').value.trim();
    try {
        await api(`/api/admin/payments/${id}/reject`, { method: 'POST', body: { note } });
        toast('Rad etildi · foydalanuvchiga xabar yuborildi');
        closeReject();
        loadPayments(currentPaymentStatus);
        loadDashboard();
    } catch (e) { toast(e.message, 'error'); }
