<!-- ============ TOAST ============ -->
<div id="toast" class="toast"></div>

<script>
'use strict';

let CSRF = <?= json_encode($csrf, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_UNESCAPED_UNICODE) ?>;

/* ===================================================================
   TOASTS
   =================================================================== */
function toast(msg, kind = 'ok') {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.toggle('error', kind === 'error');
    el.classList.add('show');
    clearTimeout(toast._t);
    toast._t = setTimeout(() => el.classList.remove('show'), 2500);
}

/* ===================================================================
   API HELPER (rolling CSRF)
   =================================================================== */
async function api(path, opts = {}) {
    const headers = Object.assign({
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': CSRF,
    }, opts.headers || {});
    if (opts.body && typeof opts.body !== 'string' && !(opts.body instanceof FormData)) {
        headers['Content-Type'] = 'application/json';
        opts.body = JSON.stringify(opts.body);
    }
    const res = await fetch(path, Object.assign({}, opts, { headers }));
    const fresh = res.headers.get('X-CSRF-Token');
    if (fresh) CSRF = fresh;
    let data;
    try { data = await res.json(); } catch { data = {}; }
    if (!res.ok) throw new Error(data.error || ('HTTP ' + res.status));
    return data;
}

/* ===================================================================
   NAVIGATION
   =================================================================== */
function activatePane(name) {
    document.querySelectorAll('.pane').forEach(p => p.classList.toggle('is-active', p.dataset.pane === name));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.toggle('is-active', n.dataset.pane === name));
    if (name === 'dashboard') loadDashboard();
    if (name === 'payments')  loadPayments(currentPaymentStatus);
    if (name === 'tariffs')   loadTariffs();
    if (name === 'exams')     loadExams();
    if (name === 'settings')  loadSettings();
}
document.querySelectorAll('.nav-item').forEach(n => {
    n.addEventListener('click', () => activatePane(n.dataset.pane));
});
document.querySelectorAll('[data-jump]').forEach(b => {
    b.addEventListener('click', () => activatePane(b.dataset.jump));
});

/* ===================================================================
   DASHBOARD
   =================================================================== */
async function loadDashboard() {
    try {
        const d = await api('/api/admin/dashboard');
        document.getElementById('kpiPending').textContent = d.pending_payments;
        document.getElementById('kpiUsers').textContent   = d.total_users;
        document.getElementById('kpiExams').textContent   = d.active_exams;
        document.getElementById('kpiRevenue').textContent = formatNum(d.today_revenue);
        document.getElementById('navPaymentsBadge').textContent = d.pending_payments;
        document.getElementById('lastRefreshDash').textContent = '↻ ' + new Date().toLocaleTimeString('uz-UZ');
    } catch (e) { toast(e.message, 'error'); }

    // Maintenance stats — fetched in parallel; failures are silent.
    try {
        const m = await api('/api/admin/maintenance');
        const s = m.stats || {};
        document.getElementById('mtRlTotal').textContent    = formatNum(s.rate_limits_total);
        document.getElementById('mtRlExpired').textContent  = formatNum(s.rate_limits_expired);
        document.getElementById('mtTgTotal').textContent    = formatNum(s.tg_sessions_total);
        document.getElementById('mtTgIdle').textContent     = formatNum(s.tg_sessions_idle_old);
        document.getElementById('mtStuckExams').textContent = formatNum(s.stale_exam_sessions);

        // Queue cells
        document.getElementById('mtQuPending').textContent    = formatNum(s.queue_pending);
        document.getElementById('mtQuProcessing').textContent = formatNum(s.queue_processing);
        document.getElementById('mtQuFailed').textContent     = formatNum(s.queue_failed);
        document.getElementById('mtQuSent24').textContent     = formatNum(s.queue_sent_24h);

        // Worker freshness check: oldest_pending older than 5 min → "stalled"
        const oldest = s.queue_oldest_pending; // string or null
        const wsEl = document.getElementById('mtWorkerStatus');
        if (!oldest) {
            wsEl.textContent = '● bo\'sh navbat';
            wsEl.style.opacity = .6;
        } else {
            const ageSec = (Date.now() - new Date(oldest.replace(' ', 'T')).getTime()) / 1000;
            if (ageSec > 300) {
                wsEl.innerHTML = '● <span style="background:#000;color:#fff;padding:0 4px;">WORKER TO\'XTAGAN</span>';
            } else {
                wsEl.textContent = '● faol (' + Math.round(ageSec) + 's)';
                wsEl.style.opacity = 1;
            }
        }
    } catch { /* best-effort */ }
}

document.getElementById('runGcBtn').addEventListener('click', async () => {
    if (!confirm('Servis tozalashni ishga tushirish?\n• Rate-limit muddati o\'tganlar\n• TG idle sessiyalar (7+ kun)\n• Tikilib qolgan imtihonlar (24h+)')) return;
    const btn = document.getElementById('runGcBtn');
    btn.disabled = true; btn.textContent = '...';
    try {
        const r = await api('/api/admin/maintenance/gc', { method:'POST', body: {} });
        const c = r.cleaned || {};
        toast(`GC OK: rl=${c.rate_limits_deleted}, tg=${c.tg_sessions_deleted}, exam=${c.exam_sessions_expired}`);
        loadDashboard();
    } catch (e) {
        toast(e.message, 'error');
    } finally {
        btn.disabled = false; btn.textContent = '↻ GC ishga tushir';
    }
});

