        document.querySelectorAll('[data-status]').forEach(x => x.classList.toggle('is-active-tab', x === b));
        document.querySelectorAll('[data-status]').forEach(x =>
            x.style.background = (x === b ? '#000' : '#fff'));
        document.querySelectorAll('[data-status]').forEach(x =>
            x.style.color      = (x === b ? '#fff' : '#000'));
        loadPayments(currentPaymentStatus);
