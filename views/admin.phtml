    const code = document.getElementById('tfaConfirmCode').value.trim();
    if (code.length !== 6) return toast('6 xonali kod kiriting', 'error');
    try {
        const r = await api('/api/auth/2fa/confirm', { method:'POST', body:{ code } });
        toast('2FA yoqildi');
        renderRecoveryCodes(r.recovery_codes);
        document.getElementById('tfaEnrollForm').classList.add('hidden');
    } catch (e) { toast(e.message, 'error'); }
});

document.getElementById('tfaRecoveryDoneBtn')?.addEventListener('click', async () => {
    document.getElementById('tfaRecoveryBlock').classList.add('hidden');
    await loadTfaStatus();
});

document.getElementById('tfaRecoveryCopyBtn')?.addEventListener('click', () => {
    const codes = Array.from(document.querySelectorAll('#tfaRecoveryGrid > span'))
        .map(s => s.textContent).join('\n');
    navigator.clipboard.writeText(codes).then(() => toast('Nusxa olindi'));
});

document.getElementById('tfaRegenBtn')?.addEventListener('click', async () => {
    const code = document.getElementById('tfaRegenCode').value.trim();
    if (!code) return toast('Kod kiriting', 'error');
    if (!confirm('Eski recovery kodlar bekor qilinadi. Davom etamizmi?')) return;
    try {
        const r = await api('/api/auth/2fa/regenerate', { method:'POST', body:{ code } });
        renderRecoveryCodes(r.recovery_codes);
        toast('Yangi recovery kodlar yaratildi');
        document.getElementById('tfaRegenCode').value = '';
    } catch (e) { toast(e.message, 'error'); }
});

document.getElementById('tfaDisableBtn')?.addEventListener('click', async () => {
    const code = document.getElementById('tfaDisableCode').value.trim();
    if (!code) return toast('Kod kiriting', 'error');
    if (!confirm("2FA ni butunlay o'chirish? Hisob xavfsizligi pasayadi.")) return;
    try {
        await api('/api/auth/2fa/disable', { method:'POST', body:{ code } });
        toast("2FA o'chirildi");
        document.getElementById('tfaDisableCode').value = '';
        await loadTfaStatus();
    } catch (e) { toast(e.message, 'error'); }
});

function renderRecoveryCodes(codes) {
    const grid = document.getElementById('tfaRecoveryGrid');
    grid.innerHTML = '';
    (codes || []).forEach(c => {
        const s = document.createElement('span');
        s.className = 'brutal p-2 text-center';
        s.textContent = c;
        grid.appendChild(s);
    });
    document.getElementById('tfaRecoveryBlock').classList.remove('hidden');
}

function renderQr(targetId, text) {
    const target = document.getElementById(targetId);
    target.innerHTML = '';
    if (typeof qrcode === 'undefined') {
        target.textContent = '(QR library yuklanmadi)';
        return;
    }
    // Type-0 = auto, 'M' = medium error correction
    const qr = qrcode(0, 'M');
    qr.addData(text);
    qr.make();
    target.innerHTML = qr.createSvgTag({ scalable: true, margin: 0 });
    const svg = target.querySelector('svg');
    if (svg) {
        svg.removeAttribute('width');
        svg.removeAttribute('height');
        svg.style.width = '100%';
        svg.style.height = '100%';
    }
}

document.getElementById('saveCardsBtn').addEventListener('click', async () => {
    const payload = {
        humo_card:   document.getElementById('humoCard').value.trim(),
        visa_card:   document.getElementById('visaCard').value.trim(),
        card_holder: document.getElementById('cardHolder').value.trim(),
    };
    try {
        await api('/api/admin/cards', { method: 'POST', body: payload });
        toast('Kartalar saqlandi');
    } catch (e) { toast(e.message, 'error'); }
});

document.getElementById('logoForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget;
    const fd = new FormData(form);
    if (!fd.get('logo') || !fd.get('logo').size) return toast('Fayl tanlanmadi', 'error');
    try {
        const d = await api('/api/admin/logo', { method: 'POST', body: fd });
        toast('Logo yangilandi');
        if (d.path) {
            document.getElementById('currentLogo').src = d.path + '?t=' + Date.now();
            document.querySelector('header img').src   = d.path + '?t=' + Date.now();
        }
        form.reset();
    } catch (err) { toast(err.message, 'error'); }
});

document.getElementById('sliderForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget;
    const fd = new FormData(form);
    if (!fd.get('slide') || !fd.get('slide').size) return toast('Fayl tanlanmadi', 'error');
    try {
        const d = await api('/api/admin/slider', { method: 'POST', body: fd });
        toast('Slayd qo\'shildi');
        renderSlider(d.images || []);
        form.reset();
    } catch (err) { toast(err.message, 'error'); }
});

function renderSlider(images) {
    const grid = document.getElementById('sliderGrid');
    if (!images || images.length === 0) {
        grid.innerHTML = '<div class="brutal p-6 text-center mono text-xs opacity-60 col-span-full">— slayder bo\'sh —</div>';
        return;
    }
    grid.innerHTML = '';
    for (const path of images) {
        const card = document.createElement('div');
        card.className = 'brutal p-2 flex flex-col gap-2';
        card.innerHTML = `
            <div class="brutal flex items-center justify-center" style="aspect-ratio:16/9;overflow:hidden;background:#fff;">
                <img src="${escapeAttr(path)}" alt="" style="max-width:100%;max-height:100%;object-fit:contain;">
            </div>
            <div class="flex items-center justify-between">
                <span class="mono text-[10px] uppercase truncate flex-1" title="${escapeAttr(path)}">${escapeHtml(path.split('/').pop())}</span>
                <button class="btn-danger" data-del="${escapeAttr(path)}">o'chir</button>
            </div>
        `;
        grid.appendChild(card);
    }
}

document.getElementById('sliderGrid').addEventListener('click', async (e) => {
    const btn = e.target.closest('button[data-del]');
    if (!btn) return;
    if (!confirm('Bu slaydni o\'chirib tashlaysizmi?')) return;
    try {
        const d = await api('/api/admin/slider/delete', { method: 'POST', body: { path: btn.dataset.del } });
        toast('O\'chirildi');
        renderSlider(d.images || []);
    } catch (err) { toast(err.message, 'error'); }
});

/* ===================================================================
   LOGOUT
   =================================================================== */
document.getElementById('logoutBtn').addEventListener('click', async () => {
    try { await api('/api/auth/logout', { method:'POST' }); } catch {}
    window.location.href = '/auth';
});

/* ===================================================================
   UTILS
   =================================================================== */
function escapeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, c => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
}
function escapeAttr(s) { return escapeHtml(s).replace(/`/g, '&#96;'); }
function formatNum(n)  { return new Intl.NumberFormat('fr-FR').format(Number(n) || 0); }
function stripTags(s)  { return String(s ?? '').replace(/<[^>]+>/g, ''); }
function truncate(s, n) {
    s = String(s ?? '');
    return s.length > n ? s.slice(0, n) + '…' : s;
}
function emptyState(text) {
    const div = document.createElement('div');
    div.className = 'mono text-xs uppercase tracking-widest opacity-50';
    div.textContent = text;
    return div;
}

/* ===================================================================
   BOOT
   =================================================================== */
loadDashboard();

// Auto-refresh dashboard every 60s
setInterval(loadDashboard, 60_000);

// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
    if (e.key === 'Escape') { closeReject(); closeShot(); }
    if (e.key === '1') activatePane('dashboard');
    if (e.key === '2') activatePane('payments');
    if (e.key === '3') activatePane('tariffs');
    if (e.key === '4') activatePane('exams');
    if (e.key === '5') activatePane('settings');
});
</script>

