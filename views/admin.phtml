/* ----------------- QUESTION EDITOR ----------------- */

function openQuestionEditor(q) {
    const ed = document.getElementById('questionEditor');
    ed.classList.remove('hidden');
    document.getElementById('qEditorTitle').textContent = q ? `[ SAVOL #${q.id} ]` : '[ YANGI SAVOL ]';
    document.getElementById('qId').value         = q ? q.id : 0;
    document.getElementById('qExamId').value     = q ? q.exam_id : (currentExam ? currentExam.id : 0);
    document.getElementById('qText').value       = q ? q.question_text : '';
    document.getElementById('qSection').value    = q ? q.section : 'Umumiy';
    document.getElementById('qType').value       = q ? q.type : 'mcq';
    document.getElementById('qDifficulty').value = q ? q.difficulty : 2;
    document.getElementById('qWeight').value     = q ? q.weight : 1.0;
    document.getElementById('qSolution').value   = q ? (q.solution_text || '') : '';
    document.getElementById('qVideoUrl').value   = q ? (q.video_url || '') : '';

    // Render type-specific editor
    renderQuestionTypeEditor();

    // Pre-fill existing answer data
    if (q && q.type === 'mcq') {
        const opts = Array.isArray(q.options) ? q.options : [];
        const correct = Array.isArray(q.correct_answer) ? q.correct_answer.map(String) : [String(q.correct_answer)];
        document.getElementById('qMcqOptions').innerHTML = '';
        opts.forEach(o => addMcqOption(o.key, o.text, correct.includes(String(o.key))));
    } else if (q && q.type === 'open') {
        document.getElementById('qOpenAnswer').value = q.correct_answer || '';
    } else if (q && q.type === 'matching') {
        document.getElementById('qMatchLeft').value  = (q.options?.left  || []).join('\n');
        document.getElementById('qMatchRight').value = (q.options?.right || []).join('\n');
        buildMatchingPairs(q.correct_answer || {});
    } else {
        // New MCQ: 4 empty rows
        document.getElementById('qMcqOptions').innerHTML = '';
        ['A','B','C','D'].forEach(k => addMcqOption(k, '', false));
    }

    refreshPreview();
    ed.scrollIntoView({ behavior:'smooth', block:'start' });
}
function closeQuestionEditor() { document.getElementById('questionEditor').classList.add('hidden'); }

document.getElementById('qType').addEventListener('change', renderQuestionTypeEditor);
function renderQuestionTypeEditor() {
    const t = document.getElementById('qType').value;
    document.getElementById('qMcqEditor').classList.toggle('hidden',      t !== 'mcq');
    document.getElementById('qOpenEditor').classList.toggle('hidden',     t !== 'open');
    document.getElementById('qMatchingEditor').classList.toggle('hidden', t !== 'matching');
    if (t === 'mcq' && document.getElementById('qMcqOptions').children.length === 0) {
        ['A','B','C','D'].forEach(k => addMcqOption(k, '', false));
    }
}

function addMcqOption(key = '', text = '', correct = false) {
    const wrap = document.getElementById('qMcqOptions');
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 brutal p-2';
    row.innerHTML = `
        <label class="flex items-center gap-1 brutal px-2 py-1.5 hover-fill cursor-pointer">
            <input type="checkbox" class="qMcqCorrect" ${correct ? 'checked' : ''}>
            <span class="mono text-[10px] uppercase tracking-widest">to'g'ri</span>
        </label>
        <input class="qMcqKey  brutal px-2 py-1.5 mono text-sm" style="width:60px;" placeholder="key" value="${escapeAttr(key)}">
        <input class="qMcqText brutal px-2 py-1.5 flex-1"        placeholder="variant matni" value="${escapeAttr(text)}">
        <button class="btn-ghost qMcqDel">×</button>
    `;
    row.querySelector('.qMcqDel').addEventListener('click', () => row.remove());
    wrap.appendChild(row);
}
document.getElementById('qAddMcqOpt').addEventListener('click', () => addMcqOption('', '', false));

document.getElementById('qBuildPairs').addEventListener('click', () => {
    buildMatchingPairs({});
});
function buildMatchingPairs(existing) {
    const left  = document.getElementById('qMatchLeft').value.split('\n').map(s=>s.trim()).filter(Boolean);
    const right = document.getElementById('qMatchRight').value.split('\n').map(s=>s.trim()).filter(Boolean);
    const wrap = document.getElementById('qMatchPairs');
    wrap.innerHTML = '';
    left.forEach(L => {
        const row = document.createElement('div');
        row.className = 'flex items-center gap-2';
        row.innerHTML = `
            <span class="brutal px-3 py-1.5 flex-1 mono">${escapeHtml(L)}</span>
            <span class="mono">→</span>
            <select class="brutal p-1.5 flex-1 qMatchSel" data-left="${escapeAttr(L)}">
                <option value="">— moslashuvni tanlang —</option>
                ${right.map(R => `<option value="${escapeAttr(R)}" ${existing[L] === R ? 'selected' : ''}>${escapeHtml(R)}</option>`).join('')}
            </select>
        `;
        wrap.appendChild(row);
    });
}

// LaTeX preview
let _previewT;
document.getElementById('qText').addEventListener('input', refreshPreview);
function refreshPreview() {
    clearTimeout(_previewT);
    _previewT = setTimeout(() => {
        const el = document.getElementById('qPreview');
        el.innerHTML = document.getElementById('qText').value;
        if (window.MathJax && window.MathJax.typesetPromise) {
            window.MathJax.typesetPromise([el]).catch(()=>{});
        }
    }, 250);
}

document.getElementById('saveQuestionBtn').addEventListener('click', async () => {
    const examId = parseInt(document.getElementById('qExamId').value, 10) || 0;
    const id     = parseInt(document.getElementById('qId').value, 10) || 0;
    const type   = document.getElementById('qType').value;

    const payload = {
        id,
        exam_id:        examId,
        section:        document.getElementById('qSection').value.trim() || 'Umumiy',
        type,
        difficulty:     parseInt(document.getElementById('qDifficulty').value, 10) || 1,
        weight:         parseFloat(document.getElementById('qWeight').value) || 1.0,
        question_text:  document.getElementById('qText').value.trim(),
        solution_text:  document.getElementById('qSolution').value.trim(),
        video_url:      document.getElementById('qVideoUrl').value.trim(),
        options:        null,
        correct_answer: null,
    };

    if (type === 'mcq') {
        const rows = document.querySelectorAll('#qMcqOptions > div');
        const opts = [];
        const correct = [];
        rows.forEach(r => {
            const key  = r.querySelector('.qMcqKey').value.trim();
            const text = r.querySelector('.qMcqText').value.trim();
            const isC  = r.querySelector('.qMcqCorrect').checked;
            if (key && text) {
                opts.push({ key, text });
                if (isC) correct.push(key);
            }
        });
        if (opts.length < 2) return toast('Kamida 2 ta variant kerak', 'error');
        if (correct.length === 0) return toast('Kamida 1 ta to\'g\'ri javob belgilang', 'error');
        payload.options = opts;
        payload.correct_answer = correct.length === 1 ? correct[0] : correct;
    } else if (type === 'open') {
        const ans = document.getElementById('qOpenAnswer').value.trim();
        if (!ans) return toast('To\'g\'ri javobni kiriting', 'error');
        payload.correct_answer = ans;
    } else if (type === 'matching') {
        const left  = document.getElementById('qMatchLeft').value.split('\n').map(s=>s.trim()).filter(Boolean);
        const right = document.getElementById('qMatchRight').value.split('\n').map(s=>s.trim()).filter(Boolean);
        if (left.length === 0 || right.length === 0) return toast('Chap va o\'ng ustun bo\'sh', 'error');
        payload.options = { left, right };
        const mapping = {};
        document.querySelectorAll('#qMatchPairs .qMatchSel').forEach(sel => {
            const L = sel.dataset.left;
            const R = sel.value;
            if (L && R) mapping[L] = R;
        });
        if (Object.keys(mapping).length !== left.length) {
            return toast('Hammasi uchun moslashuvni tanlang', 'error');
        }
        payload.correct_answer = mapping;
    }

    try {
        await api('/api/admin/questions', { method: 'POST', body: payload });
        toast('Savol saqlandi');
        closeQuestionEditor();
        loadQuestions(currentExam.id);
    } catch (err) { toast(err.message, 'error'); }
});

