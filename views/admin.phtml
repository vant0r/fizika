<div id="shotModal" class="modal-bg"><div class="bg-white rounded-2xl max-w-3xl w-full shadow-xl p-4"><div class="flex justify-between mb-3"><h3 class="font-bold text-lg">Chek rasmi</h3><button class="btn-o" onclick="closeShot()">Yopish</button></div><img id="shotImg" alt="screenshot" class="w-full rounded-lg"></div></div>

<!-- Toast -->
<div id="toast" class="toast"></div>

<script>
'use strict';
let CSRF = <?= json_encode($csrf, JSON_HEX_TAG|JSON_HEX_AMP|JSON_HEX_APOS|JSON_HEX_QUOT|JSON_UNESCAPED_UNICODE) ?>;

function toast(msg, type='ok') { const el=document.getElementById('toast'); el.textContent=msg; el.classList.toggle('err',type==='error'); el.classList.add('show'); clearTimeout(toast._t); toast._t=setTimeout(()=>el.classList.remove('show'),2500); }
function esc(s){return String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function fmtNum(n){return new Intl.NumberFormat('fr-FR').format(Number(n)||0);}
function stripTags(s){return String(s??'').replace(/<[^>]+>/g,'');}
function truncate(s,n){s=String(s??'');return s.length>n?s.slice(0,n)+'…':s;}

async function api(path,opts={}){
    const h=Object.assign({'X-Requested-With':'XMLHttpRequest','X-CSRF-Token':CSRF},opts.headers||{});
    if(opts.body&&typeof opts.body!=='string'&&!(opts.body instanceof FormData)){h['Content-Type']='application/json';opts.body=JSON.stringify(opts.body);}
    const res=await fetch(path,Object.assign({},opts,{headers:h}));
    const fresh=res.headers.get('X-CSRF-Token'); if(fresh) CSRF=fresh;
    let data; try{data=await res.json();}catch{data={};}
    if(!res.ok) throw new Error(data.error||('HTTP '+res.status));
    return data;
}

// ===== Navigation =====
function activatePane(name){
    document.querySelectorAll('.pane').forEach(p=>p.classList.toggle('show',p.dataset.pane===name));
    document.querySelectorAll('.nav-btn').forEach(n=>n.classList.toggle('active',n.dataset.pane===name));
    document.getElementById('pageTitle').textContent={dashboard:'Dashboard',payments:"To'lovlar",tariffs:'Tariflar',exams:'Imtihonlar',settings:'Sozlamalar'}[name]||name;
    if(name==='dashboard')loadDashboard(); if(name==='payments')loadPayments(curPayStatus); if(name==='tariffs')loadTariffs(); if(name==='exams')loadExams(); if(name==='settings')loadSettings();
}
document.querySelectorAll('.nav-btn').forEach(n=>n.addEventListener('click',()=>activatePane(n.dataset.pane)));
document.querySelectorAll('[data-jump]').forEach(b=>b.addEventListener('click',()=>activatePane(b.dataset.jump)));

// ===== Dashboard =====
async function loadDashboard(){
    try{const d=await api('/api/admin/dashboard');document.getElementById('kpiPending').textContent=d.pending_payments;document.getElementById('kpiUsers').textContent=fmtNum(d.total_users);document.getElementById('kpiExams').textContent=d.active_exams;document.getElementById('kpiRevenue').textContent=fmtNum(d.today_revenue);document.getElementById('navPayBadge').textContent=d.pending_payments;document.getElementById('lastRefresh').textContent='↻ '+new Date().toLocaleTimeString();}catch(e){toast(e.message,'error');}
    try{const m=await api('/api/admin/maintenance');const s=m.stats||{};document.getElementById('mtRlExp').textContent=s.rate_limits_expired??0;document.getElementById('mtQuPending').textContent=s.queue_pending??0;document.getElementById('mtStuck').textContent=s.stale_exam_sessions??0;}catch{}
}
document.getElementById('runGcBtn').addEventListener('click',async()=>{try{const r=await api('/api/admin/maintenance/gc',{method:'POST',body:{}});toast('GC: rl='+r.cleaned.rate_limits_deleted+' tg='+r.cleaned.tg_sessions_deleted);loadDashboard();}catch(e){toast(e.message,'error');}});


// ===== Payments =====
let curPayStatus='pending';
document.querySelectorAll('[data-status]').forEach(b=>b.addEventListener('click',()=>{curPayStatus=b.dataset.status;document.querySelectorAll('[data-status]').forEach(x=>{x.classList.toggle('active-tab',x===b);x.style.background=x===b?'#0ea5e9':'';x.style.color=x===b?'#fff':'';x.style.borderColor=x===b?'#0ea5e9':'';});loadPayments(curPayStatus);}));
(()=>{const f=document.querySelector('[data-status="pending"]');if(f){f.style.background='#0ea5e9';f.style.color='#fff';f.style.borderColor='#0ea5e9';}})();
async function loadPayments(status){const b=document.getElementById('paymentsBody');b.innerHTML='<div class="p-8 text-center text-sm text-gray-400">Yuklanmoqda...</div>';try{const d=await api('/api/admin/payments?status='+status);renderPayments(d.items,status);}catch(e){b.innerHTML=`<div class="p-8 text-center text-sm text-red-500">${esc(e.message)}</div>`;}}
function renderPayments(items,status){const b=document.getElementById('paymentsBody');if(!items||!items.length){b.innerHTML='<div class="p-8 text-center text-sm text-gray-400">Bo\'sh</div>';return;}b.innerHTML='';items.forEach(p=>{const row=document.createElement('div');row.className='tbl-row flex items-center gap-4 px-5 py-4 text-sm';const actions=status==='pending'?`<button class="btn-p text-xs" data-act="approve" data-id="${p.id}">✓ Tasdiqlash</button><button class="btn-d text-xs" data-act="reject" data-id="${p.id}">✗ Rad</button>`:'<span class="text-xs text-gray-400">'+(p.note||'—')+'</span>';row.innerHTML=`<div class="flex-1 min-w-0"><div class="font-semibold text-gray-900">${esc(p.fullname)}</div><div class="text-xs text-gray-500">${esc(p.phone)} · ${esc(p.tariff_name)} · ${p.mock_count} mock</div></div><div class="font-bold text-sky-700">${fmtNum(p.amount)}</div><button class="btn-o text-xs" data-act="view" data-shot="${esc(p.screenshot_path)}">Chek</button><div class="text-xs text-gray-400 w-28">${esc((p.created_at||'').replace('T',' '))}</div><div class="flex gap-2">${actions}</div>`;b.appendChild(row);});}
document.getElementById('paymentsBody').addEventListener('click',async(e)=>{const btn=e.target.closest('button[data-act]');if(!btn)return;if(btn.dataset.act==='view'){document.getElementById('shotImg').src=btn.dataset.shot;document.getElementById('shotModal').classList.add('show');return;}if(btn.dataset.act==='approve'){if(!confirm('Tasdiqlaysizmi?'))return;btn.disabled=true;try{await api(`/api/admin/payments/${btn.dataset.id}/approve`,{method:'POST',body:{}});toast('Tasdiqlandi');loadPayments(curPayStatus);loadDashboard();}catch(err){toast(err.message,'error');btn.disabled=false;}return;}if(btn.dataset.act==='reject'){document.getElementById('rejectId').textContent=btn.dataset.id;document.getElementById('rejectModal').dataset.id=btn.dataset.id;document.getElementById('rejectNote').value='';document.getElementById('rejectModal').classList.add('show');}});
document.getElementById('confirmRejectBtn').addEventListener('click',async()=>{const id=document.getElementById('rejectModal').dataset.id;try{await api(`/api/admin/payments/${id}/reject`,{method:'POST',body:{note:document.getElementById('rejectNote').value.trim()}});toast('Rad etildi');closeReject();loadPayments(curPayStatus);loadDashboard();}catch(e){toast(e.message,'error');}});
function closeReject(){document.getElementById('rejectModal').classList.remove('show');}
function closeShot(){document.getElementById('shotModal').classList.remove('show');}
document.getElementById('rejectModal').addEventListener('click',(e)=>{if(e.target.id==='rejectModal')closeReject();});
document.getElementById('shotModal').addEventListener('click',(e)=>{if(e.target.id==='shotModal')closeShot();});

// ===== Tariffs =====
let tariffsCache=[];
async function loadTariffs(){const b=document.getElementById('tariffsBody');b.innerHTML='<div class="p-8 text-center text-sm text-gray-400">Yuklanmoqda...</div>';try{const d=await api('/api/admin/tariffs');tariffsCache=d.items||[];if(!tariffsCache.length){b.innerHTML='<div class="p-8 text-center text-sm text-gray-400">Tariflar yo\'q</div>';return;}b.innerHTML='';tariffsCache.forEach(t=>{const row=document.createElement('div');row.className='tbl-row flex items-center gap-4 px-5 py-4 text-sm';row.innerHTML=`<div class="flex-1"><div class="font-semibold text-gray-900">${esc(t.name)}</div><div class="text-xs text-gray-500">${esc(t.description||'')} · ${t.mock_count} mock</div></div><div class="font-bold text-sky-700">${fmtNum(t.price)} so'm</div><span class="badge ${Number(t.is_active)?'badge-green':'badge-red'}">${Number(t.is_active)?'Faol':'Arxiv'}</span><div class="flex gap-2"><button class="btn-o text-xs" data-act="edit" data-id="${t.id}">Tahrir</button><button class="btn-d text-xs" data-act="delete" data-id="${t.id}">Arxiv</button></div>`;b.appendChild(row);});}catch(e){b.innerHTML=`<div class="p-8 text-center text-sm text-red-500">${esc(e.message)}</div>`;}}
document.getElementById('tariffsBody').addEventListener('click',async(e)=>{const btn=e.target.closest('button[data-act]');if(!btn)return;const id=+btn.dataset.id;if(btn.dataset.act==='edit'){const t=tariffsCache.find(x=>+x.id===id);if(t)openTariffEditor(t);}if(btn.dataset.act==='delete'){if(!confirm('Arxivga?'))return;try{await api(`/api/admin/tariffs/${id}/delete`,{method:'POST',body:{}});toast('Arxivlandi');loadTariffs();}catch(err){toast(err.message,'error');}}});
document.getElementById('addTariffBtn').addEventListener('click',()=>openTariffEditor(null));
document.getElementById('closeTariffEditor').addEventListener('click',()=>document.getElementById('tariffEditor').classList.add('hidden'));
function openTariffEditor(t){const ed=document.getElementById('tariffEditor');ed.classList.remove('hidden');document.getElementById('tariffEditorTitle').textContent=t?'Tarifni tahrirlash':'Yangi tarif';document.getElementById('tfId').value=t?t.id:0;document.getElementById('tfName').value=t?t.name:'';document.getElementById('tfPrice').value=t?t.price:'';document.getElementById('tfMockCount').value=t?t.mock_count:1;document.getElementById('tfDescription').value=t?(t.description||''):'';document.getElementById('tfSortOrder').value=t?t.sort_order:0;document.getElementById('tfIsActive').checked=t?!!Number(t.is_active):true;ed.scrollIntoView({behavior:'smooth'});}
document.getElementById('saveTariffBtn').addEventListener('click',async()=>{const p={id:+document.getElementById('tfId').value||0,name:document.getElementById('tfName').value.trim(),price:+document.getElementById('tfPrice').value||0,mock_count:+document.getElementById('tfMockCount').value||0,description:document.getElementById('tfDescription').value.trim(),sort_order:+document.getElementById('tfSortOrder').value||0,is_active:document.getElementById('tfIsActive').checked?1:0};if(!p.name)return toast('Nomni kiriting','error');try{await api('/api/admin/tariffs',{method:'POST',body:p});toast('Saqlandi');document.getElementById('tariffEditor').classList.add('hidden');loadTariffs();}catch(e){toast(e.message,'error');}});


// ===== Exams + Questions =====
let examsCache=[],currentExam=null;
async function loadExams(){document.getElementById('examsListView').classList.remove('hidden');document.getElementById('questionsView').classList.add('hidden');const b=document.getElementById('examsBody');b.innerHTML='<div class="p-8 text-center text-sm text-gray-400">Yuklanmoqda...</div>';try{const d=await api('/api/admin/exams');examsCache=d.items||[];if(!examsCache.length){b.innerHTML='<div class="p-8 text-center text-sm text-gray-400">Imtihonlar yo\'q</div>';return;}b.innerHTML='';examsCache.forEach(e=>{const row=document.createElement('div');row.className='tbl-row flex items-center gap-4 px-5 py-4 text-sm';const st=e.status==='published'?'badge-green':e.status==='archived'?'badge-red':'badge-amber';row.innerHTML=`<div class="flex-1"><div class="font-semibold text-gray-900">${esc(e.title)}</div><div class="text-xs text-gray-500">${esc(e.subject)} · ${e.duration} min · ${e.questions_count}/${e.total_qty} savol</div></div><span class="badge ${st}">${e.status}</span><div class="text-xs text-gray-400">${e.submissions_count} topsh.</div><div class="flex gap-2"><button class="btn-o text-xs" data-act="questions" data-id="${e.id}">Savollar</button><button class="btn-o text-xs" data-act="edit" data-id="${e.id}">Tahrir</button><button class="btn-d text-xs" data-act="delete" data-id="${e.id}">Arxiv</button></div>`;b.appendChild(row);});}catch(e){b.innerHTML=`<div class="p-8 text-center text-sm text-red-500">${esc(e.message)}</div>`;}}
document.getElementById('examsBody').addEventListener('click',async(e)=>{const btn=e.target.closest('button[data-act]');if(!btn)return;const id=+btn.dataset.id;const exam=examsCache.find(x=>+x.id===id);if(btn.dataset.act==='edit')openExamEditor(exam);if(btn.dataset.act==='questions')enterQuestionsView(exam);if(btn.dataset.act==='delete'){if(!confirm('Arxivga?'))return;try{await api(`/api/admin/exams/${id}/delete`,{method:'POST',body:{}});toast('Arxivlandi');loadExams();}catch(err){toast(err.message,'error');}}});
document.getElementById('addExamBtn').addEventListener('click',()=>openExamEditor(null));
function openExamEditor(e){const ed=document.getElementById('examEditor');ed.classList.remove('hidden');document.getElementById('examEditorTitle').textContent=e?'Imtihonni tahrirlash':'Yangi imtihon';document.getElementById('exId').value=e?e.id:0;document.getElementById('exTitle').value=e?e.title:'';document.getElementById('exSubject').value=e?(e.subject||'Fizika'):'Fizika';document.getElementById('exDuration').value=e?e.duration:120;document.getElementById('exTotalQty').value=e?e.total_qty:30;document.getElementById('exStatus').value=e?e.status:'draft';ed.scrollIntoView({behavior:'smooth'});}
function closeExamEditor(){document.getElementById('examEditor').classList.add('hidden');}
document.getElementById('saveExamBtn').addEventListener('click',async()=>{const p={id:+document.getElementById('exId').value||0,title:document.getElementById('exTitle').value.trim(),subject:document.getElementById('exSubject').value.trim(),duration:+document.getElementById('exDuration').value||0,total_qty:+document.getElementById('exTotalQty').value||0,status:document.getElementById('exStatus').value};if(!p.title)return toast('Sarlavha kiriting','error');try{await api('/api/admin/exams',{method:'POST',body:p});toast('Saqlandi');closeExamEditor();loadExams();}catch(e){toast(e.message,'error');}});

function enterQuestionsView(exam){if(!exam)return;currentExam=exam;document.getElementById('examsListView').classList.add('hidden');document.getElementById('questionsView').classList.remove('hidden');document.getElementById('qExamTitle').textContent=exam.title;document.getElementById('qExamId').value=exam.id;closeQuestionEditor();loadQuestions(exam.id);}
document.getElementById('backToExams').addEventListener('click',()=>{currentExam=null;loadExams();});
async function loadQuestions(examId){const list=document.getElementById('questionsList');list.innerHTML='<div class="card p-8 text-center text-sm text-gray-400">Yuklanmoqda...</div>';try{const d=await api(`/api/admin/exams/${examId}/questions`);if(!d.items||!d.items.length){list.innerHTML='<div class="card p-8 text-center text-sm text-gray-400">Savollar yo\'q</div>';return;}list.innerHTML='';d.items.forEach((q,idx)=>{const card=document.createElement('div');card.className='card p-4 hover:border-sky-300 transition';const stars='★'.repeat(q.difficulty)+'☆'.repeat(5-q.difficulty);card.innerHTML=`<div class="flex items-start justify-between gap-3"><div class="flex-1 min-w-0"><div class="flex items-center gap-2 flex-wrap mb-1"><span class="badge badge-sky">#${idx+1}</span><span class="badge badge-sky">${q.type.toUpperCase()}</span><span class="badge badge-amber">${esc(q.section)}</span><span class="text-xs text-amber-500">${stars}</span></div><div class="text-sm text-gray-700 question-preview">${truncate(stripTags(q.question_text),200)}</div></div><div class="flex gap-2 flex-shrink-0"><button class="btn-o text-xs" data-act="qedit" data-id="${q.id}">Tahrir</button><button class="btn-d text-xs" data-act="qdelete" data-id="${q.id}">O'chir</button></div></div>`;list.appendChild(card);});if(window.MathJax&&window.MathJax.typesetPromise)window.MathJax.typesetPromise([list]).catch(()=>{});}catch(err){list.innerHTML=`<div class="card p-8 text-center text-sm text-red-500">${esc(err.message)}</div>`;}}
document.getElementById('questionsList').addEventListener('click',async(e)=>{const btn=e.target.closest('button[data-act]');if(!btn)return;const id=+btn.dataset.id;if(btn.dataset.act==='qdelete'){if(!confirm('O\'chirilsinmi?'))return;try{await api(`/api/admin/questions/${id}/delete`,{method:'POST',body:{}});toast('O\'chirildi');loadQuestions(currentExam.id);}catch(err){toast(err.message,'error');}return;}if(btn.dataset.act==='qedit'){try{const q=await api(`/api/admin/questions/${id}`);openQuestionEditor(q);}catch(err){toast(err.message,'error');}}});
document.getElementById('addQuestionBtn').addEventListener('click',()=>openQuestionEditor(null));


// Question editor
function openQuestionEditor(q){const ed=document.getElementById('questionEditor');ed.classList.remove('hidden');document.getElementById('qEditorTitle').textContent=q?`Savol #${q.id}`:'Yangi savol';document.getElementById('qId').value=q?q.id:0;document.getElementById('qExamId').value=q?q.exam_id:(currentExam?currentExam.id:0);document.getElementById('qText').value=q?q.question_text:'';document.getElementById('qSection').value=q?q.section:'Umumiy';document.getElementById('qType').value=q?q.type:'mcq';document.getElementById('qDifficulty').value=q?q.difficulty:2;document.getElementById('qWeight').value=q?q.weight:1.0;document.getElementById('qSolution').value=q?(q.solution_text||''):'';document.getElementById('qVideoUrl').value=q?(q.video_url||''):'';renderQuestionTypeEditor();if(q&&q.type==='mcq'){const opts=Array.isArray(q.options)?q.options:[];const correct=Array.isArray(q.correct_answer)?q.correct_answer.map(String):[String(q.correct_answer)];document.getElementById('qMcqOptions').innerHTML='';opts.forEach(o=>addMcqOption(o.key,o.text,correct.includes(String(o.key))));}else if(q&&q.type==='open'){document.getElementById('qOpenAnswer').value=q.correct_answer||'';}else if(q&&q.type==='matching'){document.getElementById('qMatchLeft').value=(q.options?.left||[]).join('\n');document.getElementById('qMatchRight').value=(q.options?.right||[]).join('\n');buildMatchingPairs(q.correct_answer||{});}else{document.getElementById('qMcqOptions').innerHTML='';['A','B','C','D'].forEach(k=>addMcqOption(k,'',false));}refreshPreview();ed.scrollIntoView({behavior:'smooth'});}
function closeQuestionEditor(){document.getElementById('questionEditor').classList.add('hidden');}
document.getElementById('qType').addEventListener('change',renderQuestionTypeEditor);
function renderQuestionTypeEditor(){const t=document.getElementById('qType').value;document.getElementById('qMcqEditor').classList.toggle('hidden',t!=='mcq');document.getElementById('qOpenEditor').classList.toggle('hidden',t!=='open');document.getElementById('qMatchingEditor').classList.toggle('hidden',t!=='matching');if(t==='mcq'&&document.getElementById('qMcqOptions').children.length===0)['A','B','C','D'].forEach(k=>addMcqOption(k,'',false));}
function addMcqOption(key='',text='',correct=false){const wrap=document.getElementById('qMcqOptions');const row=document.createElement('div');row.className='flex items-center gap-2';row.innerHTML=`<label class="flex items-center gap-1 cursor-pointer bg-sky-50 rounded-lg px-2 py-1.5"><input type="checkbox" class="qMcqCorrect w-3.5 h-3.5 text-sky-600 rounded" ${correct?'checked':''}><span class="text-[10px] text-sky-700 font-semibold">✓</span></label><input class="qMcqKey input-f" style="width:50px" placeholder="Key" value="${esc(key)}"><input class="qMcqText input-f flex-1" placeholder="Variant matni" value="${esc(text)}"><button class="btn-d text-xs qMcqDel">×</button>`;row.querySelector('.qMcqDel').addEventListener('click',()=>row.remove());wrap.appendChild(row);}
document.getElementById('qAddMcqOpt').addEventListener('click',()=>addMcqOption('','',false));
document.getElementById('qBuildPairs').addEventListener('click',()=>buildMatchingPairs({}));
function buildMatchingPairs(existing){const left=document.getElementById('qMatchLeft').value.split('\n').map(s=>s.trim()).filter(Boolean);const right=document.getElementById('qMatchRight').value.split('\n').map(s=>s.trim()).filter(Boolean);const wrap=document.getElementById('qMatchPairs');wrap.innerHTML='';left.forEach(L=>{const row=document.createElement('div');row.className='flex items-center gap-2';row.innerHTML=`<span class="text-sm font-medium flex-1 bg-sky-50 rounded-lg px-2 py-1">${esc(L)}</span><span class="text-gray-400">→</span><select class="input-f flex-1 qMatchSel" data-left="${esc(L)}"><option value="">—</option>${right.map(R=>`<option value="${esc(R)}" ${existing[L]===R?'selected':''}>${esc(R)}</option>`).join('')}</select>`;wrap.appendChild(row);});}
let _prevT;document.getElementById('qText').addEventListener('input',refreshPreview);
function refreshPreview(){clearTimeout(_prevT);_prevT=setTimeout(()=>{const el=document.getElementById('qPreview');el.innerHTML=document.getElementById('qText').value;if(window.MathJax&&window.MathJax.typesetPromise)window.MathJax.typesetPromise([el]).catch(()=>{});},250);}
document.getElementById('saveQuestionBtn').addEventListener('click',async()=>{const type=document.getElementById('qType').value;const payload={id:+document.getElementById('qId').value||0,exam_id:+document.getElementById('qExamId').value||0,section:document.getElementById('qSection').value.trim()||'Umumiy',type,difficulty:+document.getElementById('qDifficulty').value||1,weight:+(document.getElementById('qWeight').value)||1,question_text:document.getElementById('qText').value.trim(),solution_text:document.getElementById('qSolution').value.trim(),video_url:document.getElementById('qVideoUrl').value.trim(),options:null,correct_answer:null};if(type==='mcq'){const rows=document.querySelectorAll('#qMcqOptions > div');const opts=[],correct=[];rows.forEach(r=>{const k=r.querySelector('.qMcqKey').value.trim();const t=r.querySelector('.qMcqText').value.trim();const c=r.querySelector('.qMcqCorrect').checked;if(k&&t){opts.push({key:k,text:t});if(c)correct.push(k);}});if(opts.length<2)return toast('Kamida 2 variant','error');if(!correct.length)return toast("To'g'ri javob belgilang",'error');payload.options=opts;payload.correct_answer=correct.length===1?correct[0]:correct;}else if(type==='open'){const ans=document.getElementById('qOpenAnswer').value.trim();if(!ans)return toast("Javobni kiriting",'error');payload.correct_answer=ans;}else if(type==='matching'){const left=document.getElementById('qMatchLeft').value.split('\n').map(s=>s.trim()).filter(Boolean);const right=document.getElementById('qMatchRight').value.split('\n').map(s=>s.trim()).filter(Boolean);if(!left.length||!right.length)return toast("Chap/o'ng bo'sh",'error');payload.options={left,right};const mapping={};document.querySelectorAll('#qMatchPairs .qMatchSel').forEach(sel=>{if(sel.dataset.left&&sel.value)mapping[sel.dataset.left]=sel.value;});if(Object.keys(mapping).length!==left.length)return toast("Hammasi uchun moslang",'error');payload.correct_answer=mapping;}try{await api('/api/admin/questions',{method:'POST',body:payload});toast('Saqlandi');closeQuestionEditor();loadQuestions(currentExam.id);}catch(e){toast(e.message,'error');}});


// ===== Settings =====
async function loadSettings(){try{const s=await api('/api/admin/settings');document.getElementById('humoCard').value=s.humo_card||'';document.getElementById('visaCard').value=s.visa_card||'';document.getElementById('cardHolder').value=s.card_holder||'';if(s.site_logo)document.getElementById('currentLogo').src=s.site_logo;renderSlider(s.slider_images||[]);}catch(e){toast(e.message,'error');}try{await loadTfaStatus();}catch{}}
document.getElementById('saveCardsBtn').addEventListener('click',async()=>{try{await api('/api/admin/cards',{method:'POST',body:{humo_card:document.getElementById('humoCard').value.trim(),visa_card:document.getElementById('visaCard').value.trim(),card_holder:document.getElementById('cardHolder').value.trim()}});toast('Saqlandi');}catch(e){toast(e.message,'error');}});
document.getElementById('logoForm').addEventListener('submit',async(e)=>{e.preventDefault();const fd=new FormData(e.currentTarget);if(!fd.get('logo')||!fd.get('logo').size)return toast('Fayl tanlanmadi','error');try{const d=await api('/api/admin/logo',{method:'POST',body:fd});toast('Logo yangilandi');if(d.path)document.getElementById('currentLogo').src=d.path+'?t='+Date.now();e.currentTarget.reset();}catch(err){toast(err.message,'error');}});
document.getElementById('sliderForm').addEventListener('submit',async(e)=>{e.preventDefault();const fd=new FormData(e.currentTarget);if(!fd.get('slide')||!fd.get('slide').size)return toast('Fayl tanlanmadi','error');try{const d=await api('/api/admin/slider',{method:'POST',body:fd});toast("Qo'shildi");renderSlider(d.images||[]);e.currentTarget.reset();}catch(err){toast(err.message,'error');}});
function renderSlider(images){const grid=document.getElementById('sliderGrid');if(!images||!images.length){grid.innerHTML='<div class="text-sm text-gray-400 col-span-full text-center py-4">Bo\'sh</div>';return;}grid.innerHTML='';images.forEach(path=>{const card=document.createElement('div');card.className='relative rounded-xl overflow-hidden border border-sky-100 group';card.innerHTML=`<img src="${esc(path)}" alt="" class="w-full aspect-video object-cover"><button class="absolute top-2 right-2 w-6 h-6 rounded-full bg-white/90 text-red-500 text-xs flex items-center justify-center opacity-0 group-hover:opacity-100 transition" data-del="${esc(path)}">×</button>`;grid.appendChild(card);});}
document.getElementById('sliderGrid').addEventListener('click',async(e)=>{const btn=e.target.closest('button[data-del]');if(!btn||!confirm("O'chirilsinmi?"))return;try{const d=await api('/api/admin/slider/delete',{method:'POST',body:{path:btn.dataset.del}});toast("O'chirildi");renderSlider(d.images||[]);}catch(err){toast(err.message,'error');}});

// ===== 2FA =====
async function loadTfaStatus(){const r=await api('/api/auth/2fa/status');const box=document.getElementById('tfaStatusBox');if(r.enabled){box.innerHTML=`<span class="inline-flex items-center gap-1.5"><svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> <strong>Yoqilgan</strong> · Recovery: <strong>${r.recovery_remaining}</strong> qoldi</span>`;document.getElementById('tfaEnrollBlock').classList.add('hidden');document.getElementById('tfaManageBlock').classList.remove('hidden');}else{box.innerHTML='<span class="text-gray-500">○ O\'chiq — hisobingizni qo\'shimcha himoya bilan ta\'minlang.</span>';document.getElementById('tfaEnrollBlock').classList.remove('hidden');document.getElementById('tfaManageBlock').classList.add('hidden');}document.getElementById('tfaEnrollForm').classList.add('hidden');document.getElementById('tfaRecoveryBlock').classList.add('hidden');}
document.getElementById('tfaEnrollStartBtn')?.addEventListener('click',async()=>{try{const r=await api('/api/auth/2fa/begin',{method:'POST',body:{}});document.getElementById('tfaSecretText').textContent=r.secret;renderQr('tfaQrBox',r.uri);document.getElementById('tfaEnrollForm').classList.remove('hidden');}catch(e){toast(e.message,'error');}});
document.getElementById('tfaCancelEnroll')?.addEventListener('click',()=>document.getElementById('tfaEnrollForm').classList.add('hidden'));
document.getElementById('tfaConfirmBtn')?.addEventListener('click',async()=>{const code=document.getElementById('tfaConfirmCode').value.trim();if(code.length!==6)return toast('6 xonali kod','error');try{const r=await api('/api/auth/2fa/confirm',{method:'POST',body:{code}});toast('2FA yoqildi');renderRecoveryCodes(r.recovery_codes);document.getElementById('tfaEnrollForm').classList.add('hidden');}catch(e){toast(e.message,'error');}});
document.getElementById('tfaRecoveryDoneBtn')?.addEventListener('click',async()=>{document.getElementById('tfaRecoveryBlock').classList.add('hidden');await loadTfaStatus();});
document.getElementById('tfaRecoveryCopyBtn')?.addEventListener('click',()=>{const codes=Array.from(document.querySelectorAll('#tfaRecoveryGrid > span')).map(s=>s.textContent).join('\n');navigator.clipboard.writeText(codes).then(()=>toast('Nusxa olindi'));});
document.getElementById('tfaRegenBtn')?.addEventListener('click',async()=>{const code=document.getElementById('tfaRegenCode').value.trim();if(!code)return toast('Kod kiriting','error');if(!confirm('Eski kodlar bekor qilinadi'))return;try{const r=await api('/api/auth/2fa/regenerate',{method:'POST',body:{code}});renderRecoveryCodes(r.recovery_codes);toast('Yangilandi');document.getElementById('tfaRegenCode').value='';}catch(e){toast(e.message,'error');}});
document.getElementById('tfaDisableBtn')?.addEventListener('click',async()=>{const code=document.getElementById('tfaDisableCode').value.trim();if(!code)return toast('Kod kiriting','error');if(!confirm("2FA o'chirilsinmi?"))return;try{await api('/api/auth/2fa/disable',{method:'POST',body:{code}});toast("O'chirildi");document.getElementById('tfaDisableCode').value='';await loadTfaStatus();}catch(e){toast(e.message,'error');}});
function renderRecoveryCodes(codes){const grid=document.getElementById('tfaRecoveryGrid');grid.innerHTML='';(codes||[]).forEach(c=>{const s=document.createElement('span');s.className='bg-white rounded-lg px-3 py-2 text-center font-mono text-sm font-bold text-amber-800 border border-amber-200';s.textContent=c;grid.appendChild(s);});document.getElementById('tfaRecoveryBlock').classList.remove('hidden');}
function renderQr(id,text){const t=document.getElementById(id);t.innerHTML='';if(typeof qrcode==='undefined'){t.textContent='QR library yuklanmadi';return;}const qr=qrcode(0,'M');qr.addData(text);qr.make();t.innerHTML=qr.createSvgTag({scalable:true,margin:0});const svg=t.querySelector('svg');if(svg){svg.removeAttribute('width');svg.removeAttribute('height');svg.style.width='100%';svg.style.height='100%';}}

// ===== Logout =====
document.getElementById('logoutBtn').addEventListener('click',async()=>{try{await api('/api/auth/logout',{method:'POST'});}catch{}window.location.href='/auth';});

// ===== Boot =====
loadDashboard();
setInterval(loadDashboard,60000);
</script>
</body>
</html>
