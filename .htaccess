## ====================================================================
##  Root .htaccess
##  Two layouts supported:
##    A) Standard: DocumentRoot != project root → rewrites to public/
##    B) x10hosting flat: DocumentRoot = public_html → no rewrite needed
##       (this file sits next to index.php, app/, views/, etc.)
##
##  The RewriteCond checks if public/ subfolder exists before redirecting.
## ====================================================================

RewriteEngine On

# Don't expose internal directories
RewriteRule ^(app|database|views|bin)(/|$) - [F,L]

# Only rewrite to public/ if public/ subfolder actually exists AND
# we're NOT already inside it. (Skipped on flat x10hosting layout.)
RewriteCond %{DOCUMENT_ROOT}/public -d
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]

<FilesMatch "^(\.env|\.git|composer\.(json|lock)|.*\.sql|.*\.md|bootstrap\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
