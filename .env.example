# =====================================================================
# Physics National Certificate — Environment Configuration
# Copy this file to `.env` and fill in real values for your environment.
# =====================================================================

# Application
APP_ENV=production
APP_TIMEZONE=Asia/Tashkent
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=please_replace_with_a_64_char_hex_key__min_32_bytes_required__

# Master DB (read+write)
DB_MASTER_DSN="mysql:host=127.0.0.1;port=3306;dbname=physics_cert;charset=utf8mb4"
DB_MASTER_USER=root
DB_MASTER_PASS=

# Read replicas (optional, comma-separated DSNs). Leave empty to skip replication.
# DB_REPLICA_DSN="mysql:host=10.0.0.11;port=3306;dbname=physics_cert;charset=utf8mb4,mysql:host=10.0.0.12;port=3306;dbname=physics_cert;charset=utf8mb4"
DB_REPLICA_DSN=
DB_REPLICA_USER=
DB_REPLICA_PASS=

# Telegram Bot
TG_BOT_TOKEN=123456:ABC-XYZ
# Random 32-64 char string. Used for the X-Telegram-Bot-Api-Secret-Token header.
TG_WEBHOOK_SECRET=please_replace_with_a_random_secret_token_min_32_chars

# SMS gateway (for OTP-gated registration)
# Provider options: "eskiz" (production) | "log" (dev — writes OTP to error_log)
SMS_PROVIDER=log
# Eskiz.uz credentials — required when SMS_PROVIDER=eskiz
SMS_ESKIZ_EMAIL=
SMS_ESKIZ_PASSWORD=
# Sender ID assigned by Eskiz (default: 4546)
SMS_FROM=4546
# Set to "1" only if you DELIBERATELY want to keep using log provider in production
# (useful for staging mirrors). Leave empty in real production.
SMS_PROVIDER_FORCE_LOG=

# Optional: APCu cache for rate limiting (auto-detected). Disable: APC_ENABLED=0
APC_ENABLED=1
